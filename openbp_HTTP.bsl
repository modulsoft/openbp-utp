Функция ДокументыИзменитьДанные(Запрос)

	Перем Пользователь;
	Перем Ответ;
	
	Идентификатор = Запрос.ПараметрыURL["uuid"];
	ТипДокумента = Запрос.ПараметрыЗапроса.Получить("type");

	УстановитьПривилегированныйРежим(Истина);
	
	UUID = Новый УникальныйИдентификатор(Идентификатор);	
	Если Не УстановитьПользователя(UUID, Пользователь, Ответ) Тогда
		Возврат Ответ;
	КонецЕсли;

	СтрокаJSON = Запрос.ПолучитьТелоКакСтроку();
	Данные = ПрочитатьJSONИзСтроки(СтрокаJSON);
	
	ДанныеРезультат = Новый Структура("status, msg, id, number", "", "", "", "");

	Если ТипДокумента = "incoming_invoice_utp" Тогда 
		Документы_ИзменитьДанныеПриходнаяНакладная(Данные, Пользователь, ДанныеРезультат);
	ИначеЕсли ТипДокумента = "supplier_order_utp" Тогда 
		Документы_ИзменитьДанныеЗаказПоставщику(Данные, Пользователь, ДанныеРезультат);		
	КонецЕсли;
	
	СтрокаДляОтвета = ОбработкаJSON.ЗаписатьJSON_Обработка(ДанныеРезультат);
	
	Результат = Новый HTTPСервисОтвет(200);	
	Результат.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
	Результат.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДобавитьЗаголовки(Результат);
	
КонецФункции

Функция СправочникиПолучитьДанные(Запрос)
	
	Перем Пользователь;
	Перем Ответ;
	
	Идентификатор = Запрос.ПараметрыURL["uuid"];
	ТипСправочника = Запрос.ПараметрыЗапроса.Получить("type");

	УстановитьПривилегированныйРежим(Истина);
	
	UUID = Новый УникальныйИдентификатор(Идентификатор);	
	Если Не УстановитьПользователя(UUID, Пользователь, Ответ) Тогда
		Возврат Ответ;
	КонецЕсли;

	МассивДанные = Новый Массив;
	
	Если ТипСправочника = "organizations" Тогда
		
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	сСправочник.Ссылка КАК Ссылка,
		               |	сСправочник.Наименование КАК Наименование,
		               |	ЕСТЬNULL(КодыОрганизацииСрезПоследних.ИНН, """") КАК ИНН,
		               |	сСправочник.НаименованиеПолное
		               |ИЗ
		               |	Справочник.Организации КАК сСправочник
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КодыОрганизации.СрезПоследних КАК КодыОрганизацииСрезПоследних
		               |		ПО сСправочник.Ссылка = КодыОрганизацииСрезПоследних.Организация
		               |ГДЕ
		               |	сСправочник.ПометкаУдаления = ЛОЖЬ";
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДЗ = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДЗ.Следующий() Цикл	
			
			СтруктураДанные = Новый Структура;
			СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка.УникальныйИдентификатор());
			СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
			СтруктураДанные.Вставить("fullName", ВыборкаДЗ.НаименованиеПолное);
			СтруктураДанные.Вставить("tin", ВыборкаДЗ.ИНН);
			МассивДанные.Добавить(СтруктураДанные);	
			
		КонецЦикла;
		
	ИначеЕсли ТипСправочника = "clients" Тогда
		
		МассивДанные = Справочники_ПолучитьДанныеКонтрагенты();
		
	ИначеЕсли ТипСправочника = "clients_hierarchy" Тогда
		
		МассивДанные = Справочники_ПолучитьДанныеКонтрагентыИерархия();		

	ИначеЕсли ТипСправочника = "nomenclature" Тогда
		
		МассивДанные = Справочники_ПолучитьДанныеНоменклатура();

	ИначеЕсли ТипСправочника = "nomenclature_hierarchy" Тогда
		
		МассивДанные = Справочники_ПолучитьДанныеНоменклатураИерархия();
		
	ИначеЕсли ТипСправочника = "warehouses" Тогда
		
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	сСправочник.Ссылка КАК Ссылка,
		               |	сСправочник.Наименование КАК Наименование
		               |ИЗ
		               |	Справочник.Склады КАК сСправочник
		               |ГДЕ
		               |	сСправочник.ПометкаУдаления = ЛОЖЬ
		               |	И НЕ сСправочник.ЭтоГруппа";
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДЗ = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДЗ.Следующий() Цикл	
			
			СтруктураДанные = Новый Структура;			
			СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка.УникальныйИдентификатор());
			СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);	
			
			МассивДанные.Добавить(СтруктураДанные);	
			
		КонецЦикла;	

	ИначеЕсли ТипСправочника = "ratesVAT" Тогда
		
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	сСправочник.Ссылка КАК Наименование,
		               |	сСправочник.Порядок
		               |ИЗ
		               |	Перечисление.СтавкиНДС КАК сСправочник";
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДЗ = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДЗ.Следующий() Цикл
			
			СтруктураДанные = Новый Структура;
			знПеречисления = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления.Получить(ВыборкаДЗ.Порядок);
			Если знПеречисления <> Неопределено Тогда
				СтруктураДанные.Вставить("id", знПеречисления.Имя);
			Иначе
				СтруктураДанные.Вставить("id", "");
			КонецЕсли;			
			СтруктураДанные.Вставить("name", знПеречисления.Представление());
			
			МассивДанные.Добавить(СтруктураДанные);
			
		КонецЦикла;
		
	ИначеЕсли ТипСправочника = "units" Тогда
		
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	сСправочник.Ссылка КАК Ссылка,
		               |	сСправочник.Наименование КАК Наименование
		               |ИЗ
		               |	Справочник.КлассификаторЕдиницИзмерения КАК сСправочник
		               |ГДЕ
		               |	сСправочник.ПометкаУдаления = ЛОЖЬ";
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДЗ = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДЗ.Следующий() Цикл
			
			СтруктураДанные = Новый Структура;
			СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка.УникальныйИдентификатор());
			СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
						
			МассивДанные.Добавить(СтруктураДанные);
			
		КонецЦикла;	
	
	ИначеЕсли ТипСправочника = "currencies" Тогда
		
		Запрос = Новый Запрос();
		Запрос.Текст = "ВЫБРАТЬ
		               |	сСправочник.Ссылка КАК Ссылка,
		               |	сСправочник.Наименование КАК Наименование
		               |ИЗ
		               |	Справочник.Валюты КАК сСправочник
		               |ГДЕ
		               |	сСправочник.ПометкаУдаления = ЛОЖЬ";
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДЗ = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДЗ.Следующий() Цикл
			
			СтруктураДанные = Новый Структура;
			СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка.УникальныйИдентификатор());
			СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
						
			МассивДанные.Добавить(СтруктураДанные);
			
		КонецЦикла;	
		
	ИначеЕсли ТипСправочника = "currencyRates" Тогда
		
		ВалютаУИД = Запрос.ПараметрыЗапроса.Получить("currency");	
		стрДата = Запрос.ПараметрыЗапроса.Получить("date");	
		
	    Валюта = Справочники.Валюты.ПолучитьСсылку(Новый УникальныйИдентификатор(ВалютаУИД));
	    Дата = Дата(стрДата);
		
		ВалютаКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата - 86400, Новый Структура("Валюта", Валюта));
		
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("id", Валюта.УникальныйИдентификатор());
		СтруктураДанные.Вставить("name", Валюта.Наименование);
		СтруктураДанные.Вставить("rate", ВалютаКурсКратность.Курс);
		СтруктураДанные.Вставить("multiplicity", ВалютаКурсКратность.Кратность);
		
		МассивДанные.Добавить(СтруктураДанные);
			
	Иначе		
		Возврат СформироватьОтветДляHTTPСервиса(404, "Не найден тип справочника!");
	КонецЕсли;	
		
	ДанныеОтвет = Новый Структура(ТипСправочника, МассивДанные);	
	СтрокаДляОтвета = ОбработкаJSON.ЗаписатьJSON_Обработка(ДанныеОтвет);
	
	Результат = Новый HTTPСервисОтвет(200);	
	Результат.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
	Результат.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДобавитьЗаголовки(Результат);

КонецФункции

Функция СправочникиИзменитьДанные(Запрос)
	
	Перем Пользователь;
	Перем Ответ;
	
	Идентификатор = Запрос.ПараметрыURL["uuid"];
	ТипСправочника = Запрос.ПараметрыЗапроса.Получить("type");

	УстановитьПривилегированныйРежим(Истина);
	
	UUID = Новый УникальныйИдентификатор(Идентификатор);	
	Если Не УстановитьПользователя(UUID, Пользователь, Ответ) Тогда
		Возврат Ответ;
	КонецЕсли;

	СтрокаJSON = Запрос.ПолучитьТелоКакСтроку();
	Данные = ПрочитатьJSONИзСтроки(СтрокаJSON);
	ДанныеРезультат = Новый Структура;
		
	Если ТипСправочника = "nomenclature" Тогда
		
		Если Данные.Свойство("id") И ЗначениеЗаполнено(Данные.id) Тогда
			Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.id));
			НоменклатураОбъект = Номенклатура.ПолучитьОбъект();
			Если НоменклатураОбъект = Неопределено Тогда
				Возврат СформироватьОтветДляHTTPСервиса(404, "Номенклатуру не найдено!");
			КонецЕсли;	
		Иначе
			НоменклатураОбъект = Справочники.Номенклатура.СоздатьЭлемент();
		КонецЕсли;	
		
		НоменклатураОбъект.Заполнить(Неопределено);
		НоменклатураОбъект.Наименование = Данные.name;
		НоменклатураОбъект.НаименованиеПолное = Данные.name;
		НоменклатураОбъект.Артикул = Данные.article;
		
		знПеречисления = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления.Найти(Данные.rate_VAT_id);
		Если знПеречисления <> Неопределено Тогда
			НоменклатураОбъект.СтавкаНДС = Перечисления.СтавкиНДС[знПеречисления.Имя];
		КонецЕсли;	
		
		Если Данные.Свойство("unit") И ЗначениеЗаполнено(Данные.unit) Тогда
			НоменклатураОбъект.БазоваяЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.unit));		
		КонецЕсли;
		
		знПеречисления = Метаданные.Перечисления.ТипыНоменклатуры.ЗначенияПеречисления.Найти(Данные.type);
		Если знПеречисления <> Неопределено Тогда
			НоменклатураОбъект.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоРеквизиту("ТипНоменклатуры", Перечисления.ТипыНоменклатуры[знПеречисления.Имя]);
		Иначе
			НоменклатураОбъект.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоРеквизиту("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Товар);	
		КонецЕсли;
					
		Попытка
			НоменклатураОбъект.Записать();
		Исключение
			Возврат СформироватьОтветДляHTTPСервиса(500, "Ошибка записи номенклатуры!");
		КонецПопытки;
		
		Номенклатура = НоменклатураОбъект.Ссылка;
		
		МассивРезультат = Справочники_ПолучитьДанныеНоменклатура(Номенклатура);
		Если МассивРезультат.Количество() Тогда
			ДанныеРезультат = МассивРезультат[0];
		КонецЕсли;
		
	КонецЕсли;
	
	СтрокаДляОтвета = ОбработкаJSON.ЗаписатьJSON_Обработка(ДанныеРезультат);
	
	Результат = Новый HTTPСервисОтвет(200);	
	Результат.Заголовки.Вставить("Content-type", "application/JSON;  charset=utf-8");
	Результат.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДобавитьЗаголовки(Результат);
	
КонецФункции

