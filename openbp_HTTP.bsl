
#Область ФункцииОбщегоНазначения

Функция ДобавитьЗаголовки(Результат)
	
	Результат.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Результат.Заголовки.Вставить("Access-Control-Allow-Methods", "*");
	Результат.Заголовки.Вставить("Access-Control-Allow-Headers", "Origin, X-Requested-With, Content-Type, Accept, Authorization");
	Возврат Результат;  
	
КонецФункции

//Функция возвращает ответ от HTTP сервиса в формате JSON
Функция СформироватьОтветДляHTTPСервиса(Статус, ТекстовоеСообщение)
	
	СтрокаДляОтвета = ОбработкаJSON.ЗаписатьJSON_Обработка(ТекстовоеСообщение);
		   
	Ответ = Новый HTTPСервисОтвет(Статус);
    Ответ.Заголовки.Вставить("Content-type", "application/json;  charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(СтрокаДляОтвета, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Возврат ДобавитьЗаголовки(Ответ)
	
КонецФункции

//Функция определяет Контакное лицо по UUID,
//проверяет доступ к порталу контактного лица
Функция УстановитьПользователя(UUID, Пользователь, Ответ)
	
	Пользователь = Справочники.Пользователи.ПолучитьСсылку(UUID);
	Если Пользователь.ПолучитьОбъект() = Неопределено Тогда
		Ответ = СформироватьОтветДляHTTPСервиса(404, "Не найден пользователь!");
		Возврат Ложь;
	КонецЕсли;
	
	//Если Пользователь.Недействителен Тогда
	//	Ответ = СформироватьОтветДляHTTPСервиса(404, "У пользователя нет доступа!");
	//	Возврат Ложь;
	//КонецЕсли;
	
	ПараметрыСеанса.ТекущийПользователь = Пользователь;
	
	Возврат Истина;
	
КонецФункции

Функция ПрочитатьJSONИзСтроки(СтрокаJSON)  
	
	ЧтениеJSON = Новый ЧтениеJSON;	
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);	
	Структура = ПрочитатьJSON(ЧтениеJSON, Ложь);		
	ЧтениеJSON.Закрыть();
	
	Возврат Структура;
		
КонецФункции

Функция ПолучитьЕдиницуИзмеренияПоНаименованию(Номенклатура, НаименованиеЕдИзм)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕдиницыИзмерения.Ссылка
	               |ИЗ
	               |	Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	               |ГДЕ
	               |	ЕдиницыИзмерения.Владелец = &Владелец
	               |	И ЕдиницыИзмерения.ЕдиницаПоКлассификатору.Наименование = &Наименование
	               |	И НЕ ЕдиницыИзмерения.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование", НаименованиеЕдИзм);
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат Справочники.ЕдиницыИзмерения.ПустаяСсылка();
	КонецЕсли;
		
КонецФункции

Функция СоздатьНоменклатуру(Пользователь, Наименование, НаименованиеЕдИзм, Артикул)  
	
	БазоваяЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию(НаименованиеЕдИзм);
	Если БазоваяЕдиницаИзмерения.Пустая() Тогда
		БазоваяЕдиницаИзмерения = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнаяЕдиницаПоКлассификатору");
	КонецЕсли;
	Если БазоваяЕдиницаИзмерения.Пустая() Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	НоменклатураОб = Справочники.Номенклатура.СоздатьЭлемент();
	НоменклатураОб.Наименование = Наименование;
	НоменклатураОб.НаименованиеПолное = Наименование;
	НоменклатураОб.Артикул = Артикул;
	НоменклатураОб.БазоваяЕдиницаИзмерения = БазоваяЕдиницаИзмерения;
	НоменклатураОб.ВидНоменклатуры = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнойВидНоменклатуры");	
	НоменклатураОб.СтавкаНДС = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнаяСтавкаНДС");	
	НоменклатураОб.Записать();
	
	ЕдиницаОбъект = Справочники.ЕдиницыИзмерения.СоздатьЭлемент();
	ЕдиницаОбъект.Наименование            = СокрЛП(БазоваяЕдиницаИзмерения);
	ЕдиницаОбъект.ЕдиницаПоКлассификатору = БазоваяЕдиницаИзмерения;
	ЕдиницаОбъект.Коэффициент             = 1;
	ЕдиницаОбъект.Владелец                = НоменклатураОб.Ссылка;
	ЕдиницаОбъект.Записать();
	
	НоменклатураОб.ЕдиницаДляОтчетов = ЕдиницаОбъект.Ссылка;
	НоменклатураОб.ЕдиницаИзмеренияМест = ЕдиницаОбъект.Ссылка;
	НоменклатураОб.ЕдиницаХраненияОстатков = ЕдиницаОбъект.Ссылка;
	НоменклатураОб.Записать();
	
	Возврат НоменклатураОб.Ссылка;
		
КонецФункции

Функция ПолучитьДоговорПоВалюте(Организация, Контрагент, Валюта)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	               |ГДЕ
	               |	ДоговорыКонтрагентов.Владелец = &Контрагент
	               |	И ДоговорыКонтрагентов.ВалютаВзаиморасчетов = &Валюта
	               |	И ДоговорыКонтрагентов.ПометкаУдаления = ЛОЖЬ
	               |	И ДоговорыКонтрагентов.Организация = &Организация";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Валюта", Валюта);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
		
КонецФункции

Процедура Документы_ИзменитьДанныеПриходнаяНакладная(Данные, Пользователь, ДанныеРезультат)
		
	Если Данные.Свойство("id") И ЗначениеЗаполнено(Данные.id) Тогда
		Документ = Документы.ПоступлениеТоваровУслуг.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.id));
		ДокументОбъект = Документ.ПолучитьОбъект();
		Если ДокументОбъект = Неопределено Тогда
			ДанныеРезультат.Вставить("status", "ERROR");
			ДанныеРезультат.Вставить("msg", "Document not found!");			
			Возврат;
		КонецЕсли;	
	Иначе
		ДокументОбъект = Документы.ПоступлениеТоваровУслуг.СоздатьДокумент();
	КонецЕсли;
	
	мВалютаРегламентированногоУчета   = глЗначениеПеременной("ВалютаРегламентированногоУчета");
	
	ДокументОбъект.Заполнить(Неопределено);
	ДокументОбъект.Дата = ТекущаяДатаСеанса();
	Попытка
	ДокументОбъект.Дата = Дата(Данные.invoice_date);
	Исключение
		// "01.07.2025"
		Попытка
		ДокументОбъект.Дата = Дата(Прав(Данные.invoice_date,4)+ Сред(Данные.invoice_date,4,2) + Лев(Данные.invoice_date,2));
		Исключение
		КонецПопытки;
	КонецПопытки;
	
	Если Данные.Свойство("customer") И Данные.customer.Свойство("id") И ЗначениеЗаполнено(Данные.customer.id) Тогда
		Попытка
		ДокументОбъект.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.customer.id));
		Исключение
		КонецПопытки
	КонецЕсли;
	Если ДокументОбъект.Организация.Пустая() Тогда
		ДокументОбъект.Организация = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнаяОрганизация");
	КонецЕсли;
	ДокументОбъект.Ответственный = Пользователь;
	ДокументОбъект.ОтражатьВБухгалтерскомУчете = Истина;
	ДокументОбъект.ОтражатьВУправленческомУчете = Истина;
	ДокументОбъект.УчитыватьНДС = Истина;
	ДокументОбъект.НомерВходящегоДокумента = Данные.invoice_number;
	ДокументОбъект.ДатаВходящегоДокумента = ДокументОбъект.Дата;

	ДокументОбъект.Комментарий = "Імпортовано через сервіс OpenBP, документ №" + Данные.invoice_number + " від " + Данные.invoice_date;
	ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПокупкаКомиссия;
	ДокументОбъект.ВидПоступления = Перечисления.ВидыПоступленияТоваров.НаСклад;
	Попытка
		ДокументОбъект.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.supplier.id));
	Исключение
	КонецПопытки;
	Если ДокументОбъект.Контрагент.Пустая() Тогда
		ДокументОбъект.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", Данные.supplier.tin);	
	КонецЕсли;	
		
	ДокументОбъект.ВалютаДокумента = мВалютаРегламентированногоУчета;
	Если ДокументОбъект.Контрагент.ОсновнойДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СПоставщиком Тогда
		ДокументОбъект.ДоговорКонтрагента = ДокументОбъект.Контрагент.ОсновнойДоговорКонтрагента;	
	Иначе	
		ДокументОбъект.ДоговорКонтрагента = ПолучитьДоговорПоВалюте(ДокументОбъект.Организация, ДокументОбъект.Контрагент, ДокументОбъект.ВалютаДокумента);
	КонецЕсли;
	
	ДокументОбъект.ТипЦен = ДокументОбъект.ДоговорКонтрагента.ТипЦен;
	Попытка
		ДокументОбъект.СуммаВключаетНДС = Булево(Данные.inсlude_vat);
	Исключение
		ДокументОбъект.СуммаВключаетНДС = ДокументОбъект.ТипЦен.ЦенаВключаетНДС;	
	КонецПопытки;	
	ДокументОбъект.БанковскийСчетКонтрагента = ДокументОбъект.Контрагент.ОсновнойБанковскийСчет;
	
	СтруктураРеквизитовДокумента = Ценообразование.ПолучитьСтруктуруРеквизитовДокументаДляЦенообразования(ДокументОбъект);
	ЗаполнениеДокументов.ПриИзмененииЗначенияДоговора(ДокументОбъект, ДокументОбъект.ВалютаДокумента, мВалютаРегламентированногоУчета, Перечисления.СпособыЗаполненияЦен.ПоЦенамНоменклатурыКонтрагентов, СтруктураРеквизитовДокумента, "Покупка", "Товары");
		
	Если Данные.Свойство("warehouse") И Данные.warehouse.Свойство("id") И ЗначениеЗаполнено(Данные.warehouse.id) Тогда
		ДокументОбъект.СкладОрдер = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.warehouse.id));
	Иначе
		ДокументОбъект.СкладОрдер = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнойСклад");
	КонецЕсли;
	
	СчетаУчета = УправлениеВзаиморасчетами.ПолучитьСчетаРасчетовСКонтрагентом(ДокументОбъект.Организация, ДокументОбъект.Контрагент, ДокументОбъект.ДоговорКонтрагента);
	
	Если ДокументОбъект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СКомитентом Тогда
		ДокументОбъект.СчетУчетаРасчетовСКонтрагентом 		= СчетаУчета.СчетРасчетов;
	Иначе
		ДокументОбъект.СчетУчетаРасчетовСКонтрагентом 		= СчетаУчета.СчетРасчетов;
		ДокументОбъект.СчетУчетаРасчетовПоАвансам    		= СчетаУчета.СчетАвансов;
		Если ДокументОбъект.ДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.Бартерный Тогда
			ДокументОбъект.СчетУчетаРасчетовСКонтрагентом 	= СчетаУчета.СчетРасчетовПриБартере;
			ДокументОбъект.СчетУчетаРасчетовПоАвансам     	= СчетаУчета.СчетАвансовПриБартере;
		КонецЕсли;	
		ДокументОбъект.СчетУчетаРасчетовПоТаре       		= СчетаУчета.СчетУчетаТары;
		ДокументОбъект.СчетУчетаРасчетовПоТареПоАвансам 	= СчетаУчета.СчетАвансовПоТаре;			
	КонецЕсли;
	ДокументОбъект.СчетУчетаНДС 							= СчетаУчета.СчетУчетаНДСПриобретений;
	ДокументОбъект.СчетУчетаНДСПодтвержденный  				= СчетаУчета.СчетУчетаНДСПриобретенийПодтвержденный;
	
	Если ЗначениеЗаполнено(ДокументОбъект.ДоговорКонтрагента.ОсновнойПроект) Тогда
		ДокументОбъект.Проект = ДокументОбъект.ДоговорКонтрагента.ОсновнойПроект;
	КонецЕсли;
	
	ДокументОбъект.Товары.Очистить();
	
	Для Каждого СтрокаЗапасы Из Данные.items Цикл
		
		СтрокаТабличнойЧасти = ДокументОбъект.Товары.Добавить();
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.item_code) Тогда
			СтрокаТабличнойЧасти.Номенклатура = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтрокаЗапасы.item_code);
		КонецЕсли;
		Если СтрокаТабличнойЧасти.Номенклатура.Пустая() Тогда
			СтрокаТабличнойЧасти.Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(СтрокаЗапасы.description, Истина);
		КонецЕсли;
		Если СтрокаТабличнойЧасти.Номенклатура.Пустая() Тогда
			СтрокаТабличнойЧасти.Номенклатура = СоздатьНоменклатуру(Пользователь, СтрокаЗапасы.description, СтрокаЗапасы.unit, СтрокаЗапасы.item_code);
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.unit) Тогда
			СтрокаТабличнойЧасти.ЕдиницаИзмерения = ПолучитьЕдиницуИзмеренияПоНаименованию(СтрокаТабличнойЧасти.Номенклатура, СтрокаЗапасы.unit);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.ЕдиницаИзмерения) Тогда
			СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаХраненияОстатков;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.Склад = ДокументОбъект.СкладОрдер;
		
		СчетаУчета = БухгалтерскийУчет.ПолучитьСчетаУчетаНоменклатуры(ДокументОбъект.Организация, СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Склад);
		СтрокаТабличнойЧасти.СчетУчетаБУ 			= СчетаУчета.СчетУчетаБУ;
		СтрокаТабличнойЧасти.НалоговоеНазначение 	= СчетаУчета.НалоговоеНазначение;
		
		Если СтрокаЗапасы.Свойство("rate_VAT_id") И ЗначениеЗаполнено(СтрокаЗапасы.rate_VAT_id) Тогда
			знПеречисления = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления.Найти(СтрокаЗапасы.rate_VAT_id);
			Если знПеречисления <> Неопределено Тогда
				СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС[знПеречисления.Имя];
			КонецЕсли;			
		КонецЕсли;
		Если СтрокаТабличнойЧасти.СтавкаНДС.Пустая() Тогда
			СтрокаТабличнойЧасти.СтавкаНДС = СтрокаТабличнойЧасти.Номенклатура.СтавкаНДС;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.Количество = СтрокаЗапасы.quantity;
		СтрокаТабличнойЧасти.Коэффициент = 1;
		ОбработкаТабличныхЧастей.РассчитатьКоличествоМестТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект);
		
		СтрокаТабличнойЧасти.Цена 		= СтрокаЗапасы.price;
		СтрокаТабличнойЧасти.Сумма 		= СтрокаЗапасы.total_price;
		ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект);
		
	КонецЦикла;	
	
	Попытка 
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		ДанныеРезультат.Вставить("status", "OK");
		ДанныеРезультат.Вставить("msg", "");			
	Исключение
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		ДанныеРезультат.Вставить("status", "ERROR");
		ДанныеРезультат.Вставить("msg", "Document posting error!");			
	КонецПопытки;	
	
	ДанныеРезультат.Вставить("id", Строка(ДокументОбъект.Ссылка.УникальныйИдентификатор()));			
	ДанныеРезультат.Вставить("number", ДокументОбъект.Номер);			

КонецПроцедуры

Процедура Документы_ИзменитьДанныеЗаказПоставщику(Данные, Пользователь, ДанныеРезультат)
		
	Если Данные.Свойство("id") И ЗначениеЗаполнено(Данные.id) Тогда
		Документ = Документы.ЗаказПоставщику.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.id));
		ДокументОбъект = Документ.ПолучитьОбъект();
		Если ДокументОбъект = Неопределено Тогда
			ДанныеРезультат.Вставить("status", "ERROR");
			ДанныеРезультат.Вставить("msg", "Document not found!");			
			Возврат;
		КонецЕсли;	
	Иначе
		ДокументОбъект = Документы.ЗаказПоставщику.СоздатьДокумент();
	КонецЕсли;
	
	мВалютаРегламентированногоУчета   = глЗначениеПеременной("ВалютаРегламентированногоУчета");
	
	ДокументОбъект.Заполнить(Неопределено);
	ДокументОбъект.Дата = ТекущаяДатаСеанса();
	Попытка
	ДокументОбъект.Дата = Дата(Данные.invoice_date);
	Исключение
		// "01.07.2025"
		Попытка
		ДокументОбъект.Дата = Дата(Прав(Данные.invoice_date,4)+ Сред(Данные.invoice_date,4,2) + Лев(Данные.invoice_date,2));
		Исключение
		КонецПопытки;
	КонецПопытки;
	
	Если Данные.Свойство("customer") И Данные.customer.Свойство("id") И ЗначениеЗаполнено(Данные.customer.id) Тогда
		Попытка
		ДокументОбъект.Организация = Справочники.Организации.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.customer.id));
		Исключение
		КонецПопытки
	КонецЕсли;
	Если ДокументОбъект.Организация.Пустая() Тогда
		ДокументОбъект.Организация = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнаяОрганизация");
	КонецЕсли;
	ДокументОбъект.Ответственный = Пользователь;
	ДокументОбъект.УчитыватьНДС = Истина;
	ДокументОбъект.ДатаПоступления = ДокументОбъект.Дата;

	ДокументОбъект.Комментарий = "Імпортовано через сервіс OpenBP, документ №" + Данные.invoice_number + " від " + Данные.invoice_date;
	ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийЗаказПоставщику.ПокупкаКомиссия;
	Попытка
		ДокументОбъект.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.supplier.id));
	Исключение
	КонецПопытки;
	Если ДокументОбъект.Контрагент.Пустая() Тогда
		ДокументОбъект.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", Данные.supplier.tin);	
	КонецЕсли;	
		
	ДокументОбъект.ВалютаДокумента = мВалютаРегламентированногоУчета;
	Если ДокументОбъект.Контрагент.ОсновнойДоговорКонтрагента.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СПоставщиком Тогда
		ДокументОбъект.ДоговорКонтрагента = ДокументОбъект.Контрагент.ОсновнойДоговорКонтрагента;	
	Иначе	
		ДокументОбъект.ДоговорКонтрагента = ПолучитьДоговорПоВалюте(ДокументОбъект.Организация, ДокументОбъект.Контрагент, ДокументОбъект.ВалютаДокумента);
	КонецЕсли;
	
	ДокументОбъект.ТипЦен = ДокументОбъект.ДоговорКонтрагента.ТипЦен;
	Попытка
		ДокументОбъект.СуммаВключаетНДС = Булево(Данные.inсlude_vat);
	Исключение
		ДокументОбъект.СуммаВключаетНДС = ДокументОбъект.ТипЦен.ЦенаВключаетНДС;	
	КонецПопытки;	
	
	СтруктураРеквизитовДокумента = Ценообразование.ПолучитьСтруктуруРеквизитовДокументаДляЦенообразования(ДокументОбъект);
	ЗаполнениеДокументов.ПриИзмененииЗначенияДоговора(ДокументОбъект, ДокументОбъект.ВалютаДокумента, мВалютаРегламентированногоУчета, Перечисления.СпособыЗаполненияЦен.ПоЦенамНоменклатурыКонтрагентов, СтруктураРеквизитовДокумента, "Покупка", "Товары");
		
	Если Данные.Свойство("warehouse") И Данные.warehouse.Свойство("id") И ЗначениеЗаполнено(Данные.warehouse.id) Тогда
		ДокументОбъект.Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные.warehouse.id));
	Иначе
		ДокументОбъект.Склад = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(Пользователь, "ОсновнойСклад");
	КонецЕсли;
			
	ДокументОбъект.Товары.Очистить();
	
	Для Каждого СтрокаЗапасы Из Данные.items Цикл
		
		СтрокаТабличнойЧасти = ДокументОбъект.Товары.Добавить();
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.item_code) Тогда
			СтрокаТабличнойЧасти.Номенклатура = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтрокаЗапасы.item_code);
		КонецЕсли;
		Если СтрокаТабличнойЧасти.Номенклатура.Пустая() Тогда
			СтрокаТабличнойЧасти.Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(СтрокаЗапасы.description, Истина);
		КонецЕсли;	
		Если СтрокаТабличнойЧасти.Номенклатура.Пустая() Тогда
			СтрокаТабличнойЧасти.Номенклатура = СоздатьНоменклатуру(Пользователь, СтрокаЗапасы.description, СтрокаЗапасы.unit, СтрокаЗапасы.item_code);
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.unit) Тогда
			СтрокаТабличнойЧасти.ЕдиницаИзмерения = ПолучитьЕдиницуИзмеренияПоНаименованию(СтрокаТабличнойЧасти.Номенклатура, СтрокаЗапасы.unit);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.ЕдиницаИзмерения) Тогда
			СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаХраненияОстатков;
		КонецЕсли;
		
		Если СтрокаЗапасы.Свойство("rate_VAT_id") И ЗначениеЗаполнено(СтрокаЗапасы.rate_VAT_id) Тогда
			знПеречисления = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления.Найти(СтрокаЗапасы.rate_VAT_id);
			Если знПеречисления <> Неопределено Тогда
				СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС[знПеречисления.Имя];
			КонецЕсли;			
		КонецЕсли;
		Если СтрокаТабличнойЧасти.СтавкаНДС.Пустая() Тогда
			СтрокаТабличнойЧасти.СтавкаНДС = СтрокаТабличнойЧасти.Номенклатура.СтавкаНДС;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.Количество = СтрокаЗапасы.quantity;
		СтрокаТабличнойЧасти.Коэффициент = 1;
		ОбработкаТабличныхЧастей.РассчитатьКоличествоМестТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект);
		
		СтрокаТабличнойЧасти.Цена 		= СтрокаЗапасы.price;
		СтрокаТабличнойЧасти.Сумма 		= СтрокаЗапасы.total_price;
		ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти, ДокументОбъект);
		
	КонецЦикла;	
	
	Попытка 
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		ДанныеРезультат.Вставить("status", "OK");
		ДанныеРезультат.Вставить("msg", "");			
	Исключение
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		ДанныеРезультат.Вставить("status", "ERROR");
		ДанныеРезультат.Вставить("msg", "Document posting error!");			
	КонецПопытки;	
	
	ДанныеРезультат.Вставить("id", Строка(ДокументОбъект.Ссылка.УникальныйИдентификатор()));			
	ДанныеРезультат.Вставить("number", ДокументОбъект.Номер);			

КонецПроцедуры

Функция Справочники_ПолучитьДанныеКонтрагенты(Контрагенты = Неопределено)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	сСправочник.Ссылка КАК Ссылка,
	               |	сСправочник.Наименование КАК Наименование,
	               |	сСправочник.НаименованиеПолное КАК НаименованиеПолное,
	               |	сСправочник.ИНН КАК ИНН,
	               |	ВЫБОР
	               |		КОГДА сСправочник.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ЮрЛицо)
	               |			ТОГДА ""Юрособа""
	               |		ИНАЧЕ ""Фізособа""
	               |	КОНЕЦ КАК ЮрФизЛицо,
	               |	ЕСТЬNULL(КИ_Телефон.Представление, """") КАК Телефон,
	               |	ЕСТЬNULL(КИ_ЭлПочта.Представление, """") КАК Почта,
	               |	ЕСТЬNULL(КИ_Адрес.Представление, """") КАК ПредставлениеАдреса,
	               |	ЕСТЬNULL(КИ_Адрес.Поле1, """") КАК Индекс,
	               |	ЕСТЬNULL(КИ_Адрес.Поле2, """") КАК Страна,
	               |	ЕСТЬNULL(КИ_Адрес.Поле3, """") КАК Район,
	               |	ЕСТЬNULL(КИ_Адрес.Поле4, """") КАК Город,
	               |	ЕСТЬNULL(КИ_Адрес.Поле6, """") КАК Улица,
	               |	ЕСТЬNULL(КИ_Адрес.Поле7, """") КАК Дом,
	               |	ЕСТЬNULL(КИ_Адрес.Поле9, """") КАК Квартира
	               |ИЗ
	               |	Справочник.Контрагенты КАК сСправочник
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КИ_Телефон
	               |		ПО (КИ_Телефон.Объект = сСправочник.Ссылка)
	               |			И (КИ_Телефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента))
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КИ_ЭлПочта
	               |		ПО (КИ_ЭлПочта.Объект = сСправочник.Ссылка)
	               |			И (КИ_ЭлПочта.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресЭлектроннойПочтыКонтрагентаДляОбменаДокументами))
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КонтактнаяИнформация КАК КИ_Адрес
	               |		ПО (КИ_Адрес.Объект = сСправочник.Ссылка)
	               |			И (КИ_Адрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента))
	               |ГДЕ
	               |	НЕ сСправочник.ПометкаУдаления
	               |	И НЕ сСправочник.ЭтоГруппа
	               |	И ВЫБОР
	               |			КОГДА &ОтборПоКонтрагентах
	               |				ТОГДА сСправочник.Ссылка В (&Контрагенты)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Контрагенты", Контрагенты);
	Запрос.УстановитьПараметр("ОтборПоКонтрагентах", Не Контрагенты = Неопределено);	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДЗ = РезультатЗапроса.Выбрать();
	
	МассивДанные = Новый Массив;
	
	Пока ВыборкаДЗ.Следующий() Цикл
		
		СтруктураАдрес = Новый Структура("country, voivodeship, district, commune, city, index, street, house, flat", 
											"", "", "", "", "", "", "", "", "");
		СтруктураАдрес.index = ВыборкаДЗ.Индекс;
		СтруктураАдрес.country = ВыборкаДЗ.Страна;
		СтруктураАдрес.voivodeship = "";
		СтруктураАдрес.district = ВыборкаДЗ.Район;
		СтруктураАдрес.commune = ВыборкаДЗ.Город;
		СтруктураАдрес.city = "";
		СтруктураАдрес.street = ВыборкаДЗ.Улица;
		СтруктураАдрес.house = ВыборкаДЗ.Дом;
		СтруктураАдрес.flat = ВыборкаДЗ.Квартира;
									
		СтруктураДанные = Новый Структура;

		СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка);
		СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
		СтруктураДанные.Вставить("fullName", ВыборкаДЗ.НаименованиеПолное);
		СтруктураДанные.Вставить("tin", ВыборкаДЗ.ИНН);
		СтруктураДанные.Вставить("legalPhysics", ВыборкаДЗ.ЮрФизЛицо);
		СтруктураДанные.Вставить("country", "");
		СтруктураДанные.Вставить("telephone", ВыборкаДЗ.Телефон);
		СтруктураДанные.Вставить("mail", ВыборкаДЗ.Почта);
		СтруктураДанные.Вставить("address_string", ВыборкаДЗ.ПредставлениеАдреса);
		СтруктураДанные.Вставить("address", СтруктураАдрес);
			
		МассивДанные.Добавить(СтруктураДанные);
		
	КонецЦикла;	
	
	Возврат МассивДанные;
	
КонецФункции

Функция Справочники_ПолучитьДанныеКонтрагентыИерархия(Контрагенты = Неопределено)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	сСправочник.Ссылка КАК Ссылка,
	               |	сСправочник.Наименование КАК Наименование,
	               |	сСправочник.Родитель
	               |ИЗ
	               |	Справочник.Контрагенты КАК сСправочник
	               |ГДЕ
	               |	сСправочник.ЭтоГруппа
	               |	И ВЫБОР
	               |			КОГДА &ОтборПоКонтрагентах
	               |				ТОГДА сСправочник.Ссылка В (&Контрагенты)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Ссылка ИЕРАРХИЯ";
	
	Запрос.УстановитьПараметр("Контрагенты", Контрагенты);
	Запрос.УстановитьПараметр("ОтборПоКонтрагентах", Не Контрагенты = Неопределено);	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДЗ = РезультатЗапроса.Выбрать();
	
	МассивДанные = Новый Массив;
	
	Пока ВыборкаДЗ.Следующий() Цикл
											
		СтруктураДанные = Новый Структура;

		СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка);
		СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
		СтруктураДанные.Вставить("parent_id", ВыборкаДЗ.Родитель);
			
		МассивДанные.Добавить(СтруктураДанные);
		
	КонецЦикла;	
	
	Возврат МассивДанные;
	
КонецФункции

Функция Справочники_ПолучитьДанныеНоменклатура(Номенклатура = Неопределено)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	сСправочник.Ссылка КАК Ссылка,
	               |	сСправочник.Наименование КАК Наименование,
	               |	сСправочник.НаименованиеПолное КАК НаименованиеПолное,
	               |	сСправочник.Артикул КАК Артикул,
	               |	сСправочник.ВидНоменклатуры.ТипНоменклатуры КАК ТипНоменклатуры,
	               |	сСправочник.СтавкаНДС КАК СтавкаНДС,
	               |	сСправочник.БазоваяЕдиницаИзмерения КАК ЕдиницаИзмерения
	               |ИЗ
	               |	Справочник.Номенклатура КАК сСправочник
	               |ГДЕ
	               |	НЕ сСправочник.ПометкаУдаления
	               |	И НЕ сСправочник.ЭтоГруппа
	               |	И ВЫБОР
	               |			КОГДА &ОтборПоНоменклатуре
	               |				ТОГДА сСправочник.Ссылка В (&Номенклатура)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ОтборПоНоменклатуре", Не Номенклатура = Неопределено);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДЗ = РезультатЗапроса.Выбрать();
	
	МассивДанные = Новый Массив;
	
	Пока ВыборкаДЗ.Следующий() Цикл
		
		Если ВыборкаДЗ.ТипНоменклатуры.Пустая() Тогда
			ТипНоменклатуры = "";	
		Иначе
			ИндексТипНоменклатуры = Перечисления.ТипыНоменклатуры.Индекс(ВыборкаДЗ.ТипНоменклатуры);
			ТипНоменклатуры = Метаданные.Перечисления.ТипыНоменклатуры.ЗначенияПеречисления[ИндексТипНоменклатуры].Имя;
		КонецЕсли;
		
		Если ВыборкаДЗ.СтавкаНДС.Пустая() Тогда
			СтавкаНДС = "";	
		Иначе
			ИндексСтавкиНДС = Перечисления.СтавкиНДС.Индекс(ВыборкаДЗ.СтавкаНДС);
			СтавкаНДС = Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления[ИндексСтавкиНДС].Имя;
		КонецЕсли;		
		
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка);
		СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
		СтруктураДанные.Вставить("fullName", ВыборкаДЗ.НаименованиеПолное);
		СтруктураДанные.Вставить("internationalName", "");			
		СтруктураДанные.Вставить("article", ВыборкаДЗ.Артикул);
		СтруктураДанные.Вставить("type", ТипНоменклатуры);						
		СтруктураДанные.Вставить("barcode", "");
		СтруктураДанные.Вставить("rate_VAT_id", СтавкаНДС);
		СтруктураДанные.Вставить("unitId", ВыборкаДЗ.ЕдиницаИзмерения);
		
		МассивДанные.Добавить(СтруктураДанные);
		
	КонецЦикла;	
	
	Возврат МассивДанные;
	
КонецФункции

Функция Справочники_ПолучитьДанныеНоменклатураИерархия(Номенклатура = Неопределено)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	сСправочник.Ссылка КАК Ссылка,
	               |	сСправочник.Наименование КАК Наименование,
	               |	сСправочник.Родитель КАК Родитель
	               |ИЗ
	               |	Справочник.Номенклатура КАК сСправочник
	               |ГДЕ
	               |	сСправочник.ЭтоГруппа
	               |	И ВЫБОР
	               |			КОГДА &ОтборПоНоменклатуре
	               |				ТОГДА сСправочник.Ссылка В (&Номенклатура)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ОтборПоНоменклатуре", Не Номенклатура = Неопределено);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДЗ = РезультатЗапроса.Выбрать();
	
	МассивДанные = Новый Массив;
	
	Пока ВыборкаДЗ.Следующий() Цикл
		
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("id", ВыборкаДЗ.Ссылка);
		СтруктураДанные.Вставить("name", ВыборкаДЗ.Наименование);
		СтруктураДанные.Вставить("parent_id", ВыборкаДЗ.Родитель);
		
		МассивДанные.Добавить(СтруктураДанные);
		
	КонецЦикла;	
	
	Возврат МассивДанные;
	
КонецФункции

